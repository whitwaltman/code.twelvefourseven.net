---
layout: layouts/base.njk
pagination:
    data: collections.decks
    size: 1
    alias: deckName
permalink: "/{{ deckName }}/index.html"
---

<h1>Deck: {{ deckName | capitalize }}</h1>

{% for card in collections.decks[deckName] %}
    <article>
        <h2>{{ card.data.title or card.fileSlug }}</h2>
        {{ card.templateContent | safe }}
        <div class="flex-row-btwn">
            <span>Updated: <time>{{ card.date }}</time></span>
            <a href="{{ card.url }}">permalink</a>
        </div>
    </article>
{% endfor %}